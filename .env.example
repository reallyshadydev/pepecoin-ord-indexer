RUST_LOG=info

# Pepecoin RPC — replace with your own credentials (never commit real values)
RPC_URL=http://your_rpc_user:your_rpc_password@127.0.0.1:33873

# Or use cookie auth instead of embedding creds in RPC_URL:
# RPC_URL=http://127.0.0.1:33873
# COOKIE_FILE=/home/you/.pepecoin/.cookie

FIRST_INSCRIPTION_HEIGHT=186920
FIRST_DUNE_HEIGHT=186920
ORD_HTTP_PORT=8080
DOG_MOUNT_DIR_INDEXER=/mnt/ord-node
COMPOSE_PROJECT_NAME=pepecoin-ord-indexer
